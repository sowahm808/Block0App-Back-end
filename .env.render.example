# Render backend environment variables for MindUnlocking.Api
# Copy these into Render Dashboard > Web Service > Environment.
# Do not commit real secrets.

# Render sets PORT automatically. Program.cs binds to it when ASPNETCORE_URLS is unset.
ASPNETCORE_ENVIRONMENT=Production

# JWT settings. SigningKey must be at least 32 characters; generate a strong random secret.
Jwt__Issuer=https://YOUR-RENDER-SERVICE.onrender.com
Jwt__Audience=mind-unlocking-api
Jwt__SigningKey=REPLACE_WITH_A_STRONG_RANDOM_SECRET_AT_LEAST_32_CHARS

# Database: this app currently uses EF Core SQL Server (UseSqlServer).
# Render managed PostgreSQL will not work unless the app is changed to Npgsql/PostgreSQL.
# Recommended production option: use an external managed SQL Server such as Azure SQL.
Sql__ConnectionString=Server=tcp:YOUR-AZURE-SQL-SERVER.database.windows.net,1433;Initial Catalog=MindUnlocking;Persist Security Info=False;User ID=YOUR-SQL-USER;Password=YOUR-SQL-PASSWORD;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;
Sql__MaxRetryCount=5

# If you deploy a separate private SQL Server container on Render, use its internal host name instead.
# Example only; replace mindunlocking-sql and the password with your private service values.
# Sql__ConnectionString=Server=mindunlocking-sql,1433;Database=MindUnlocking;User Id=sa;Password=YOUR_STRONG_SA_PASSWORD;Encrypt=True;TrustServerCertificate=True;Connection Timeout=30;

# CORS origins for your frontend. Add one indexed variable per allowed frontend URL.
Cors__AllowedOrigins__0=https://YOUR-FRONTEND.onrender.com
Cors__AllowedOrigins__1=https://YOUR-CUSTOM-DOMAIN.example

# Challenge defaults. Override only if your production rules differ.
Challenge__DefaultTeamMinSize=3
Challenge__DefaultTeamMaxSize=4
Challenge__DurationDays=21
